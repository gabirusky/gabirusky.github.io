---
import { siteData } from '../data/siteData';
---

<section id="contact" class="py-32 px-6 relative z-10 w-full overflow-hidden flex flex-col items-center justify-center min-h-[60vh]">
  
  <!-- Subtle glowing core under the CTA -->
  <div class="absolute w-[600px] h-[300px] bg-pulse/10 rounded-full blur-[100px] -z-10 animate-pulse pointer-events-none"></div>

  <div class="max-w-3xl mx-auto text-center animate-section-reveal flex flex-col items-center">
    
    <p class="font-mono text-pulse mb-6 flex items-center justify-center gap-3">
      <span class="w-8 h-px bg-pulse/50"></span>
      / INICIAR CONEXÃO
      <span class="w-8 h-px bg-pulse/50"></span>
    </p>

    <h2 class="text-4xl md:text-6xl font-bold mb-8 tracking-tighter">
      Pronto para o próximo<span class="text-gradient"> desafio</span>
    </h2>

    <p class="text-dim text-lg mb-12 max-w-xl mx-auto leading-relaxed">
      Se você tem um problema real que precisa de código de excelência, trago dedicação técnica, visão criativa e a energia de quem ainda tem muito a provar. Vamos construir algo juntos?
    </p>

    <a href={`mailto:${siteData.email}`}
      class="inline-block relative overflow-hidden bg-void border border-pulse/50 px-8 py-4 md:px-12 md:py-6 rounded-full font-bold font-mono text-sm md:text-xl text-pulse transition-all duration-300 hover:-translate-y-1 hover:text-void z-20 group">
      
      <!-- Scanline slide inside hover -->
      <div class="absolute inset-0 bg-pulse transform -translate-x-full transition-transform duration-300 ease-out group-hover:translate-x-0 -z-10"></div>
      
      <!-- Default neon pulsing box shadow -->
      <div class="absolute inset-0 rounded-full animate-neon-pulse -z-20 pointer-events-none"></div>

      <i class="fas fa-envelope mr-3 opacity-70 group-hover:opacity-100 mix-blend-difference text-white"></i> 
      <span class="relative z-10 mix-blend-difference text-white">{siteData.email}</span>
    </a>
    
  </div>
</section>
