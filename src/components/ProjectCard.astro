---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  githubUrl: string;
  icon: string;
  brandIcon: string;
  primaryColor: string;
  index: number;
}

const { title, description, tags, githubUrl, icon, brandIcon, primaryColor, index } = Astro.props;

// Calculate delay based on index for staggered animations
const delay = index * 100;

// Dynamic tailwind class builder for arbitrary colors requires safe-listing or inline styles
// Fortunately, we can use exact tailwind utility strings in Astro through dynamic expression evaluation.
---

<!-- 
Using group class for specific hover targeting and overflow-hidden for the glowing aura
-->
<div class={`glass-panel rounded-2xl p-8 group relative overflow-hidden animate-section-reveal`} style={`animation-delay: ${delay}ms;`}>
  
  <!-- The inner glowing orb, mapped roughly to the primary color requested using Tailwind's arbitrary values -->
  <div class={`absolute top-0 right-0 w-32 h-32 blur-3xl rounded-full transition-all opacity-20 group-hover:opacity-40`}
       style={`background-color: var(--${primaryColor}, var(--color-${primaryColor}, currentColor));`}>
  </div>

  <div class="flex justify-between items-start mb-6 relative z-10">
    <i class={`${icon} text-3xl`} style={`color: var(--color-${primaryColor});`}></i>
    <i class={`${brandIcon} text-2xl text-dim group-hover:text-star transition-colors`}></i>
  </div>
  
  <h3 class="text-2xl font-bold mb-2 transition-colors relative z-10" style={`--hover-color: var(--color-${primaryColor});`} onmouseover="this.style.color = this.style.getPropertyValue('--hover-color');" onmouseout="this.style.color = '';">
    {title}
  </h3>
  
  <p class="text-dim text-sm mb-6 h-20 relative z-10 leading-relaxed">
    {description}
  </p>
  
  <div class="flex flex-wrap gap-2 mb-6 font-mono text-xs relative z-10" style={`color: var(--color-${primaryColor});`}>
    {tags.map((tag) => (
      <span class="border px-2 py-1 rounded border-current opacity-60">
        {tag}
      </span>
    ))}
  </div>
  
  <a href={githubUrl} target="_blank" rel="noopener noreferrer"
    class="text-sm font-bold flex items-center gap-2 w-fit relative z-10 group/link transition-colors"
    style={`--hover-color: var(--color-${primaryColor});`} onmouseover="this.style.color = this.style.getPropertyValue('--hover-color');" onmouseout="this.style.color = '';">
    Ver Código <i class="fas fa-arrow-right group-hover/link:translate-x-1 transition-transform"></i>
  </a>
</div>
