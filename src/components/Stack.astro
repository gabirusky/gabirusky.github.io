---
import { siteData } from '../data/siteData';

// We duplicate the array to ensure flawless infinite CSS looping
const skillsRepeated = [...siteData.skills, ...siteData.skills];
---

<section id="skills" class="py-20 border-y border-glass-border bg-void relative overflow-hidden z-10">
  
  <div class="max-w-7xl mx-auto px-6 mb-10">
    <h3 class="text-pulse font-mono flex items-center gap-3">
      <span class="w-8 h-px bg-pulse"></span>
      / STACK TÉCNICA
    </h3>
  </div>

  <!-- Marquee Container -->
  <div class="flex overflow-hidden relative w-[100vw] left-1/2 -ml-[50vw]">
    
    <!-- Fades on the edges of the marquee -->
    <div class="absolute top-0 bottom-0 left-0 w-32 bg-gradient-to-r from-void to-transparent z-10 pointer-events-none"></div>
    <div class="absolute top-0 bottom-0 right-0 w-32 bg-gradient-to-l from-void to-transparent z-10 pointer-events-none"></div>

    <!-- Scrolling Inner -->
    <div class="flex gap-12 items-center whitespace-nowrap px-6 w-max animate-orbit" style="animation: scroll-left 40s linear infinite;">
      
      {skillsRepeated.map((skill) => (
        <div class="flex items-center gap-4 group cursor-default">
          <i class={`${skill.icon} text-4xl text-dim group-hover:${skill.colorClass} transition-colors duration-300`}></i>
          <span class="text-3xl font-bold font-sans text-glass-border group-hover:text-star transition-colors duration-300 tracking-wider">
            {skill.name}
          </span>
          <span class="text-nebula text-2xl mx-6 opacity-30 group-hover:opacity-100 transition-opacity">•</span>
        </div>
      ))}

    </div>
  </div>
  
  <!-- Add custom keyframe just for this horizontal scroll -->
  <style>
    @keyframes scroll-left {
      0% {
        transform: translateX(0%);
      }
      100% {
        transform: translateX(-50%);
      }
    }
  </style>

</section>
