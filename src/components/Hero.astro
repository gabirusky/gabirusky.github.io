---
import { siteData } from '../data/siteData';

// We extract first name and join the rest for styling
const nameParts = siteData.name.split(' ');
const firstName = nameParts.shift();
const lastName = nameParts.join(' ');
---

<section class="min-h-screen flex items-center justify-center px-6 relative pt-20 pb-10">
  <div class="max-w-[100vw] lg:max-w-none mx-auto w-full lg:w-fit z-10 animate-section-reveal">
    <div class="relative w-full group">
      <!-- Glowing aura behind the entire card -->
      <div class="absolute -inset-1 bg-gradient-to-br from-pulse/30 to-nebula/30 rounded-[2.5rem] blur-2xl opacity-40 group-hover:opacity-80 transition duration-1000"></div>
      
      <!-- Big Glass Card -->
      <div class="glass-panel rounded-[2.5rem] p-8 lg:px-14 lg:py-12 relative flex flex-col-reverse items-center lg:flex-row justify-center gap-12 lg:gap-14 animate-float overflow-hidden">
        
        <!-- Subtle scanline overlay inside card -->
        <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.1)_50%)] bg-[length:100%_4px] pointer-events-none opacity-20 z-10"></div>
        
        <!-- Left: Profile Info (Now rendered first) -->
        <div class="relative z-20 flex flex-col items-center lg:min-w-[300px]">
          <!-- Profile Image Ring Pulse -->
          <div class="relative w-48 h-48 sm:w-56 sm:h-56 mb-8 flex items-center justify-center">
             <!-- Sonar ring 1 -->
             <div class="absolute inset-0 rounded-full border border-pulse/30 animate-pulse-ring"></div>
             <!-- Sonar ring 2 -->
             <div class="absolute inset-0 rounded-full border border-nebula/30 animate-pulse-ring" style="animation-delay: 1.25s"></div>
             
             <!-- Avatar frame -->
             <div class="w-full h-full rounded-full border-2 border-glass-border bg-deep flex items-center justify-center overflow-hidden z-20 group-hover:border-pulse/50 transition-colors duration-500">
                <img src="/profile.png" alt={siteData.name} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity duration-500 grayscale hover:grayscale-0" />
             </div>
          </div>
          
          <div class="text-center w-full z-20 bg-void/30 backdrop-blur-sm p-4 rounded-2xl border border-glass-border shadow-[inset_0_0_15px_rgba(255,255,255,0.01)]">
            <h3 class="font-mono text-xl font-bold tracking-widest mb-1 text-star">@gabirusky</h3>
            <div class="w-full h-px bg-gradient-to-r from-transparent via-glass-border to-transparent my-4"></div>
            
            <ul class="text-left font-mono text-sm space-y-2 text-dim inline-block">
              <li class="flex items-center gap-2">
                <i class="fas fa-satellite-dish text-pulse"></i> 
                Status: <span class="text-star">Online</span>
              </li>
              <li class="flex items-center gap-2">
                <i class="fas fa-code text-nebula"></i> 
                Class: <span class="text-star">Full Stack</span>
              </li>
              <li class="flex items-center gap-2">
                <i class="fas fa-brain text-pulse"></i> 
                Trait: <span class="text-star">AI-First</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Right: Text content (Now rendered second) -->
        <div class="flex-1 relative z-20 text-center lg:text-left">
          <p class="text-dim font-mono mb-4 text-sm sm:text-base">
            &gt; inicializando perfil...
          </p>
          
          <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl mb-6 leading-[1.1] font-bold tracking-tight select-none">
            {firstName}<br />
            <span class="text-star block mt-2 text-4xl sm:text-5xl md:text-6xl">{lastName}</span>
          </h1>
          
          <p class="text-xl sm:text-2xl md:text-3xl mb-4 font-mono text-gradient font-bold tracking-tight">
            {siteData.role}
          </p>
          
          <p class="text-dim max-w-lg mx-auto lg:mx-0 text-base sm:text-lg mb-10 leading-relaxed">
            {siteData.heroBio.replace(/\*\*/g, '')}
          </p>
          
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4">
            <a href="#projects"
              class="px-6 sm:px-8 py-3 sm:py-4 bg-star text-void font-bold rounded hover:bg-pulse hover:scale-105 transition-all duration-300">
              Ver Projetos
            </a>
            <a href={siteData.socials.github} target="_blank" rel="noopener noreferrer"
              class="px-6 sm:px-8 py-3 sm:py-4 border border-glass-border rounded hover:border-star hover:bg-glass transition-all flex items-center gap-2 group/btn">
              <i class="fab fa-github group-hover/btn:text-pulse transition-colors"></i> GitHub ↗
            </a>
          </div>
        </div>


        </div>
        
      </div>
    </div>
  </div>
</section>
